# PostgreSQL 連線字串 (Supabase / Neon / Railway / Vercel Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/erp?schema=public"

# 遠端資料庫或 Serverless 環境可依實測調整。Prisma 預設交易 timeout 只有 5 秒。
PRISMA_TRANSACTION_MAX_WAIT_MS="10000"
PRISMA_TRANSACTION_TIMEOUT_MS="15000"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="please-change-me-to-a-long-random-string"

# 預設管理員 (僅 seed 用)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="請設定至少8字元且不可提交到Git"
ADMIN_EMAIL="admin@example.com"

# 通知信（Vercel API Route 透過 Gmail SMTP 寄送）
GMAIL_USER="erin20080306@gmail.com"
GMAIL_APP_PASSWORD=""
CONTACT_TO_EMAIL="erin20080306@gmail.com"

# 中央授權簽章。私鑰只放中央 Vercel；本機安裝只放公鑰。
LICENSE_ED25519_PRIVATE_KEY_B64=""
LICENSE_ED25519_PUBLIC_KEY_B64=""
LICENSE_KEY_SECRET=""
LICENSE_DEVICE_SECRET=""
LICENSE_AUDIT_SECRET=""
INTEGRITY_SECRET=""
CRON_SECRET=""

# 電子發票。2026 年正式 Turnkey 以 MIG 4.1 為基準；VAN 規格依選定服務商。
# MOCK 只允許 NEXTAUTH_URL 為 localhost / 127.0.0.1 且明確開啟測試旗標。
EINVOICE_PROVIDER=""
EINVOICE_ALLOW_MOCK="false"
EINVOICE_ENV="TEST"
EINVOICE_MIG_VERSION="4.1"
EINVOICE_SELLER_TAX_ID=""
EINVOICE_TURNKEY_OUTBOX_DIR=""
EINVOICE_TURNKEY_ACK_DIR=""
EINVOICE_VAN_NAME=""
EINVOICE_VAN_BASE_URL=""
EINVOICE_VAN_CLIENT_ID=""
EINVOICE_VAN_CLIENT_SECRET=""
