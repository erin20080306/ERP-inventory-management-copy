{
  "name": "inventory-management-system",
  "version": "1.0.0",
  "private": true,
  "author": "艾琳設計",
  "description": "專業 ERP 進銷存會計管理系統",
  "scripts": {
    "generate:host-installers": "node scripts/generate-embedded-host-installers.mjs",
    "predev": "npm run generate:host-installers",
    "prebuild": "npm run generate:host-installers && node scripts/deploy-vercel-migrations.mjs",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:rehearse": "node scripts/verify-database-recovery.mjs",
    "test:fulfillment": "tsx scripts/verify-partial-fulfillment.ts",
    "test:pos": "tsx scripts/verify-pos-refunds.ts",
    "test:pos-hardware": "tsx scripts/verify-pos-hardware-simulation.ts",
    "test:pos-offers": "tsx scripts/verify-pos-offers.ts",
    "test:pos-restaurant": "tsx scripts/verify-restaurant-pos.ts",
    "test:commerce": "tsx scripts/verify-commerce-checkout.ts",
    "test:storefront": "tsx scripts/verify-storefront-access.ts",
    "test:storefront-members": "node --import tsx scripts/verify-storefront-members.ts",
    "test:company-profile": "node scripts/verify-company-profile-change.mjs",
    "test:pos-recovery": "tsx scripts/verify-pos-recovery.ts",
    "test:backup": "tsx scripts/verify-encrypted-backup.ts",
    "test:einvoice": "tsx scripts/verify-einvoice-readiness.ts",
    "test:commercial": "tsx scripts/verify-commercial-licensing.ts",
    "test:commercial-contact": "tsx scripts/verify-commercial-contact.ts",
    "test:demo-lifecycle": "tsx scripts/verify-demo-lifecycle.ts",
    "test:platform-admin": "tsx scripts/verify-platform-admin.ts",
    "test:accounting": "tsx scripts/verify-accounting-controls.ts",
    "test:resilience": "tsx scripts/verify-resilience.ts",
    "test:release": "node scripts/verify-release-config.mjs",
    "test:desktop": "node scripts/verify-desktop-package.mjs && node scripts/verify-activation-refresh.mjs",
    "test:update": "node scripts/verify-host-update.mjs",
    "test:depreciation": "tsx scripts/verify-fixed-asset-depreciation.ts",
    "test:discovery": "tsx scripts/verify-company-discovery.ts",
    "release:check": "node scripts/check-release-env.mjs",
    "desktop:install": "npm --prefix desktop ci",
    "desktop:start": "npm --prefix desktop start",
    "desktop:pack": "npm --prefix desktop run pack",
    "desktop:dist:mac": "npm --prefix desktop run dist:mac",
    "desktop:dist:mac:manual": "npm --prefix desktop run dist:mac:manual",
    "desktop:dist:mac:test": "npm --prefix desktop run dist:mac:test",
    "desktop:dist:win": "npm --prefix desktop run dist:win",
    "desktop:dist:win:manual": "npm --prefix desktop run dist:win:manual",
    "desktop:dist:win:test": "npm --prefix desktop run dist:win:test",
    "release:host": "node scripts/build-host-installers.mjs",
    "release:manifest": "node scripts/write-release-manifest.mjs",
    "release:upload-private": "node scripts/upload-private-installers.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:demo": "tsx scripts/create-local-demo-accounts.ts",
    "db:reset": "prisma migrate reset --force",
    "test:speed": "node scripts/verify-speed-patch.mjs && node scripts/verify-pos-fast-checkout-v5.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.454.0",
    "next": "^15.5.18",
    "next-auth": "^4.24.10",
    "next-themes": "^0.4.3",
    "nodemailer9": "npm:nodemailer@^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.13.3",
    "sonner": "^1.7.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.16",
    "postcss": "^8.5.14",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "next-auth": {
      "nodemailer": "^9.0.3"
    },
    "postcss": "$postcss",
    "uuid": "^11.1.1"
  }
}
