{
  "name": "erin-erp-pos-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "艾琳 ERP macOS 與 Windows 安全工作站（依授權提供 ERP／零售 POS／餐飲 POS）",
  "author": "艾琳設計",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:mac:test": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --arm64",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:win:test": "electron-builder --win nsis --x64 --config.win.signExecutable=false"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "design.erin.erp.desktop",
    "productName": "艾琳 ERP",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "../dist/desktop"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "hardware-preload.cjs",
      "setup.html",
      "setup.css",
      "setup.js",
      "package.json",
      "!node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "ErinERP-Desktop-macOS-${arch}.${ext}"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "ErinERP-Desktop-Windows-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "艾琳 ERP"
    }
  }
}
