  children       ChartOfAccount[]   @relation("AccountTree")
  lines          JournalEntryLine[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum JournalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  POSTED
  VOIDED
  REJECTED
}

model JournalEntry {
  id                     String                  @id @default(cuid())
  tenantId               String
  number                 String
  entryDate              DateTime                @default(now())
  summary                String
  status                 JournalStatus           @default(DRAFT)
  attachment             String?
  createdById            String?
  submittedById          String?
  submittedAt            DateTime?
  approvedById           String?
  approvedAt             DateTime?
  postedById             String?
  postedAt               DateTime?
  reversedById           String?
  reversedAt             DateTime?
  reversalOfId           String?                 @unique
  reversalReason         String?
  updatedBy              String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  createdBy              User?                   @relation("JournalEntryCreator", fields: [createdById], references: [id])
  lines                  JournalEntryLine[]
  reversalOf             JournalEntry?           @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversal               JournalEntry?           @relation("JournalReversal")
  closingForPeriod       AccountingPeriod[]      @relation("AccountingPeriodClosingJournal")
  fixedAssetDepreciation FixedAssetDepreciation? @relation("FixedAssetDepreciationJournal")

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, entryDate])
  @@index([tenantId, status])
  @@index([reversalOfId])
}

model JournalEntryLine {
  id        String         @id @default(cuid())
