model SalesOrderItem {
  id            String              @id @default(cuid())
  orderId       String
  productId     String
  quantity      Decimal             @db.Decimal(18, 4)
  shippedQty    Decimal             @default(0) @db.Decimal(18, 4)
  returnedQty   Decimal             @default(0) @db.Decimal(18, 4)
  unitPrice     Decimal             @db.Decimal(18, 4)
  discount      Decimal             @default(0) @db.Decimal(18, 2)
  taxRate       Decimal             @default(0) @db.Decimal(6, 4)
  subtotal      Decimal             @db.Decimal(18, 2)
  order         SalesOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product             @relation(fields: [productId], references: [id])
  shipmentItems SalesShipmentItem[]
  returnItems   SalesReturnItem[]
}

enum FulfillmentStatus {
  POSTED
  VOIDED
}

model PurchaseReceipt {
  id          String                @id @default(cuid())
  tenantId    String
  orderId     String
  warehouseId String
  number      String
  receiptDate DateTime              @default(now())
  status      FulfillmentStatus     @default(POSTED)
