  @@unique([tenantId, number])
  @@index([tenantId, receiptDate])
  @@index([orderId, createdAt])
  @@index([warehouseId, createdAt])
}

model PurchaseReceiptItem {
  id          String            @id @default(cuid())
  receiptId   String
  orderItemId String
  productId   String
  quantity    Decimal           @db.Decimal(18, 4)
  unitPrice   Decimal           @db.Decimal(18, 4)
  discount    Decimal           @default(0) @db.Decimal(18, 2)
  taxRate     Decimal           @default(0) @db.Decimal(6, 4)
  subtotal    Decimal           @db.Decimal(18, 2)
  receipt     PurchaseReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  orderItem   PurchaseOrderItem @relation(fields: [orderItemId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])

  @@unique([receiptId, orderItemId])
  @@index([orderItemId])
  @@index([productId])
}

model SalesShipment {
  id           String              @id @default(cuid())
  tenantId     String
  orderId      String
  warehouseId  String
  number       String
  shipmentDate DateTime            @default(now())
  status       FulfillmentStatus   @default(POSTED)
  subtotal     Decimal             @default(0) @db.Decimal(18, 2)
  discount     Decimal             @default(0) @db.Decimal(18, 2)
  taxAmount    Decimal             @default(0) @db.Decimal(18, 2)
  total        Decimal             @default(0) @db.Decimal(18, 2)
  cogs         Decimal             @default(0) @db.Decimal(18, 2)
  remark       String?
  createdById  String?
  createdAt    DateTime            @default(now())
  voidedAt     DateTime?
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order        SalesOrder          @relation(fields: [orderId], references: [id])
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])
  items        SalesShipmentItem[]
  receivable   AccountsReceivable?

  @@unique([tenantId, number])
  @@index([tenantId, shipmentDate])
  @@index([orderId, createdAt])
  @@index([warehouseId, createdAt])
}

model SalesShipmentItem {
  id          String         @id @default(cuid())
  shipmentId  String
  orderItemId String
  productId   String
  quantity    Decimal        @db.Decimal(18, 4)
  unitPrice   Decimal        @db.Decimal(18, 4)
  discount    Decimal        @default(0) @db.Decimal(18, 2)
  taxRate     Decimal        @default(0) @db.Decimal(6, 4)
  subtotal    Decimal        @db.Decimal(18, 2)
  unitCost    Decimal        @default(0) @db.Decimal(18, 4)
  shipment    SalesShipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem   SalesOrderItem @relation(fields: [orderItemId], references: [id])
  product     Product        @relation(fields: [productId], references: [id])

  @@unique([shipmentId, orderItemId])
  @@index([orderItemId])
  @@index([productId])
}

// ─────────────────────────── POS 門市 ───────────────────────────
enum PosShiftStatus {
  OPEN
  CLOSED
}

enum PosSaleStatus {
  COMPLETED
  PARTIALLY_REFUNDED
  VOIDED
  REFUNDED
}

enum PosRefundStatus {
  COMPLETED
  VOIDED
}

enum PosReturnDisposition {
  SELLABLE
  DAMAGED
  SCRAP
}

enum PosOfferKind {
  PERCENT
  AMOUNT
}

enum PosApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CONSUMED
  EXPIRED
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  REFUND
  ADJUST
}

enum PosCashMovementType {
  PAID_IN
  PAID_OUT
  SAFE_DROP
}

enum PosOperationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PosHeldSaleStatus {
  HELD
  RESUMED
  CANCELLED
}

enum ElectronicInvoiceProvider {
  MOCK
  TURNKEY
  VAC
  VAN
}

enum ElectronicInvoiceStatus {
  QUEUED
  ISSUED
  FAILED
  VOIDED
}

enum ElectronicInvoiceEventType {
  ISSUE
  VOID
  ALLOWANCE
}

enum ElectronicInvoiceEventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model PosRegister {
  id               String            @id @default(cuid())
  tenantId         String
  warehouseId      String
  code             String
  name             String
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id])
  shifts           PosShift[]
  sales            PosSale[]
  refunds          PosRefund[]
  cashMovements    PosCashMovement[]
  heldSales        PosHeldSale[]
  restaurantOrders RestaurantOrder[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([warehouseId])
}

model PosShift {
  id               String            @id @default(cuid())
  tenantId         String
  registerId       String
  userId           String
  closedById       String?
  status           PosShiftStatus    @default(OPEN)
  openingCash      Decimal           @default(0) @db.Decimal(18, 2)
  expectedCash     Decimal?          @db.Decimal(18, 2)
  closingCash      Decimal?          @db.Decimal(18, 2)
  difference       Decimal?          @db.Decimal(18, 2)
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register         PosRegister       @relation(fields: [registerId], references: [id])
  sales            PosSale[]
  refunds          PosRefund[]
  cashMovements    PosCashMovement[]
  heldSales        PosHeldSale[]
  cartDrafts       PosCartDraft[]
  restaurantOrders RestaurantOrder[]

  @@index([tenantId, status])
  @@index([registerId, status])
  @@index([userId, status])
  @@index([closedById])
  @@index([openedAt])
}

model PosCashMovement {
  id            String              @id @default(cuid())
  tenantId      String
  shiftId       String
  registerId    String
  type          PosCashMovementType
  status        PosOperationStatus  @default(PENDING)
  amount        Decimal             @db.Decimal(18, 2)
  reason        String
  requestedById String
  approvedById  String?
  requestedAt   DateTime            @default(now())
  decidedAt     DateTime?
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift         PosShift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  register      PosRegister         @relation(fields: [registerId], references: [id])

  @@index([tenantId, status, requestedAt])
  @@index([shiftId, status])
  @@index([registerId, requestedAt])
}

model PosHeldSale {
  id          String            @id @default(cuid())
  tenantId    String
  shiftId     String
  registerId  String
  label       String
  status      PosHeldSaleStatus @default(HELD)
  payload     Json
  createdById String
  resumedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  resumedAt   DateTime?
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift       PosShift          @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  register    PosRegister       @relation(fields: [registerId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([shiftId, status])
  @@index([registerId, status])
}

model PosCartDraft {
  id        String   @id @default(cuid())
  tenantId  String
  shiftId   String
  userId    String
  payload   Json
  revision  Int      @default(1)
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift     PosShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shiftId, userId])
  @@index([tenantId, updatedAt])
}

model PosPromotion {
  id        String       @id @default(cuid())
  tenantId  String
  code      String
  name      String
  kind      PosOfferKind
  value     Decimal      @db.Decimal(18, 2)
  minSpend  Decimal      @default(0) @db.Decimal(18, 2)
  priority  Int          @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales     PosSale[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive, startsAt, endsAt])
}

model PosCoupon {
  id               String                @id @default(cuid())
  tenantId         String
  code             String
  name             String
  kind             PosOfferKind
  value            Decimal               @db.Decimal(18, 2)
  minSpend         Decimal               @default(0) @db.Decimal(18, 2)
  maxDiscount      Decimal?              @db.Decimal(18, 2)
  maxUses          Int?
  perCustomerLimit Int                   @default(1)
  usedCount        Int                   @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions      PosCouponRedemption[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive, startsAt, endsAt])
}

model PosCouponRedemption {
  id         String    @id @default(cuid())
  tenantId   String
  couponId   String
  saleId     String    @unique
  customerId String?
  amount     Decimal   @db.Decimal(18, 2)
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon     PosCoupon @relation(fields: [couponId], references: [id])
  sale       PosSale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@index([couponId, customerId])
  @@index([tenantId, createdAt])
}

model PosManagerApproval {
  id            String            @id @default(cuid())
  tenantId      String
  kind          String
  fingerprint   String
  status        PosApprovalStatus @default(PENDING)
  payload       Json
  requestedById String
  decidedById   String?
  saleId        String?           @unique
  reason        String?
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime          @default(now())
  decidedAt     DateTime?
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale          PosSale?          @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([fingerprint, status])
}

model CustomerLoyaltyTransaction {
  id           String                 @id @default(cuid())
  tenantId     String
  customerId   String
  saleId       String
  type         LoyaltyTransactionType
  points       Int
  balanceAfter Int
  createdAt    DateTime               @default(now())
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale         PosSale                @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([saleId, type])
  @@index([customerId, createdAt])
  @@index([tenantId, createdAt])
}

model ElectronicInvoice {
  id            String                    @id @default(cuid())
  tenantId      String
  posSaleId     String                    @unique
  provider      ElectronicInvoiceProvider
  status        ElectronicInvoiceStatus   @default(QUEUED)
  mode          String
  invoiceNumber String?
  randomCode    String?
  buyerTaxId    String?
  carrierType   String?
  carrierId     String?
  donationCode  String?
  printMark     Boolean                   @default(false)
  issuedAt      DateTime?
  voidedAt      DateTime?
  lastError     String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posSale       PosSale                   @relation(fields: [posSaleId], references: [id], onDelete: Cascade)
  events        ElectronicInvoiceEvent[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, invoiceNumber])
}

model ElectronicInvoiceEvent {
  id                  String                       @id @default(cuid())
  tenantId            String
  invoiceId           String
  type                ElectronicInvoiceEventType
  status              ElectronicInvoiceEventStatus @default(PENDING)
  payload             Json
  attempts            Int                          @default(0)
  nextRetryAt         DateTime?
  processingStartedAt DateTime?
  providerRequestId   String?
  providerResponse    Json?
  lastError           String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  processedAt         DateTime?
  tenant              Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice             ElectronicInvoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, nextRetryAt])
  @@index([status, processingStartedAt])
  @@index([invoiceId, createdAt])
}

model PosSale {
  id                    String                       @id @default(cuid())
  tenantId              String
  clientRequestId       String?
  shiftId               String
  registerId            String
  customerId            String?
  salesOrderId          String?                      @unique
  exchangeRefundId      String?                      @unique
  promotionId           String?
  number                String
  status                PosSaleStatus                @default(COMPLETED)
  subtotal              Decimal                      @default(0) @db.Decimal(18, 2)
  discount              Decimal                      @default(0) @db.Decimal(18, 2)
  promotionDiscount     Decimal                      @default(0) @db.Decimal(18, 2)
  couponDiscount        Decimal                      @default(0) @db.Decimal(18, 2)
  pointsDiscount        Decimal                      @default(0) @db.Decimal(18, 2)
  loyaltyPointsEarned   Int                          @default(0)
  loyaltyPointsRedeemed Int                          @default(0)
  taxAmount             Decimal                      @default(0) @db.Decimal(18, 2)
  total                 Decimal                      @default(0) @db.Decimal(18, 2)
  paidAmount            Decimal                      @default(0) @db.Decimal(18, 2)
  changeDue             Decimal                      @default(0) @db.Decimal(18, 2)
  receiptNo             String?
  voidReason            String?
  voidedAt              DateTime?
  createdAt             DateTime                     @default(now())
  tenant                Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift                 PosShift                     @relation(fields: [shiftId], references: [id])
  register              PosRegister                  @relation(fields: [registerId], references: [id])
  customer              Customer?                    @relation(fields: [customerId], references: [id])
  salesOrder            SalesOrder?                  @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  exchangeRefund        PosRefund?                   @relation("PosExchange", fields: [exchangeRefundId], references: [id], onDelete: SetNull)
  promotion             PosPromotion?                @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  items                 PosSaleItem[]
  payments              PosPayment[]
  refunds               PosRefund[]
  electronicInvoice     ElectronicInvoice?
  couponRedemption      PosCouponRedemption?
  managerApproval       PosManagerApproval?
  loyaltyTransactions   CustomerLoyaltyTransaction[]
  restaurantOrder        RestaurantOrder?
  medicalAppointment     MedicalAppointment?
  medicalPackagePurchase MedicalPackagePurchase?
  medicalReceipt         MedicalReceipt?

  @@unique([tenantId, number])
  @@unique([tenantId, clientRequestId])
  @@index([tenantId, createdAt])
  @@index([shiftId, createdAt])
  @@index([registerId, createdAt])
  @@index([status])
