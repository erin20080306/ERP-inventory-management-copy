// ─────────────────────────── 餐飲桌位／廚房 ───────────────────────────
enum RestaurantTableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum RestaurantOrderStatus {
  OPEN
  SENT
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum RestaurantItemStatus {
  PENDING
  SENT
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum RestaurantTicketStatus {
  NEW
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum RestaurantCancellationDisposition {
  NOT_PREPARED
  WASTE
}

model RestaurantArea {
  id        String            @id @default(cuid())
  tenantId  String
  code      String
  name      String
  sortOrder Int               @default(0)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables    RestaurantTable[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive, sortOrder])
}

model RestaurantTable {
  id        String                @id @default(cuid())
  tenantId  String
  areaId    String
  code      String
  name      String
  seats     Int                   @default(4)
  status    RestaurantTableStatus @default(AVAILABLE)
  sortOrder Int                   @default(0)
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  area      RestaurantArea        @relation(fields: [areaId], references: [id], onDelete: Cascade)
  orders    RestaurantOrder[]

  @@unique([tenantId, code])
  @@index([tenantId, status, isActive])
  @@index([areaId, sortOrder])
}

model RestaurantOrder {
  id          String                    @id @default(cuid())
  tenantId    String
  tableId     String
  shiftId     String
  registerId  String
  posSaleId   String?                   @unique
  number      String
  status      RestaurantOrderStatus     @default(OPEN)
  guests      Int                       @default(1)
  note        String?
  createdById String
  openedAt    DateTime                  @default(now())
  sentAt      DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  updatedAt   DateTime                  @updatedAt
  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table       RestaurantTable           @relation(fields: [tableId], references: [id])
  shift       PosShift                  @relation(fields: [shiftId], references: [id])
  register    PosRegister               @relation(fields: [registerId], references: [id])
  posSale     PosSale?                  @relation(fields: [posSaleId], references: [id], onDelete: SetNull)
  items       RestaurantOrderItem[]
  tickets     RestaurantKitchenTicket[]

  @@unique([tenantId, number])
  @@index([tenantId, status, openedAt])
  @@index([tableId, status])
  @@index([shiftId, status])
}

model RestaurantOrderItem {
  id                String                             @id @default(cuid())
  orderId           String
  productId         String
  quantity          Decimal                            @db.Decimal(18, 4)
  unitPrice         Decimal                            @db.Decimal(18, 4)
  note              String?
  course            String?
  status            RestaurantItemStatus               @default(PENDING)
  cancelReason      String?
  cancelDisposition RestaurantCancellationDisposition?
  cancelledAt       DateTime?
  cancelledById     String?
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt
  order             RestaurantOrder                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product                            @relation(fields: [productId], references: [id])
  ticketItems       RestaurantKitchenTicketItem[]

  @@index([orderId, status])
  @@index([productId])
}

