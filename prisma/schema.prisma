// 專業 ERP 進銷存會計管理系統 - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── 租戶 (Multi-Tenant) ───────────────────────────
model Tenant {
  id           String   @id @default(cuid())
  name         String   @default("我的公司")
  businessMode String   @default("ERP") // ERP 或 POS
  // 平台管理者自己的免費測試帳套，不列入客戶、授權或營收統計。
  isInternal   Boolean  @default(false)
  createdAt    DateTime @default(now())

  // 授權一律綁定公司，不綁定個別使用者；日期由中央伺服器判定。
  licensePlan            String?
  licenseBilling         String?
  licenseStatus          String    @default("TRIAL")
  licenseSeatLimit       Int       @default(2)
  licenseActivatedAt     DateTime?
  licenseExpiresAt       DateTime?
  licenseMaintenanceEnd  DateTime?
  licenseKeyHash         String?   @unique
  licenseKeyPrefix       String?
  licenseVersion         Int       @default(0)
  licenseUpdatedAt       DateTime?
  companyCode            String?   @unique
  discoveryServerUrl     String?
  discoveryCaCertificate String?
  discoveryEnabled       Boolean   @default(false)
  discoveryVersion       Int       @default(0)
  discoveryUpdatedAt     DateTime?

  users                    User[]
  productCategories        ProductCategory[]
  productUnits             ProductUnit[]
  products                 Product[]
  customers                Customer[]
  storefrontMembers        StorefrontMember[]
  storefrontMemberSessions StorefrontMemberSession[]
  storefrontPayments       StorefrontPayment[]
  suppliers                Supplier[]
  warehouses               Warehouse[]
  inventoryStocks          InventoryStock[]
  inventoryTxns            InventoryTransaction[]
  stockAdjustments         StockAdjustment[]
  stockTransfers           StockTransfer[]
  purchaseOrders           PurchaseOrder[]
  salesOrders              SalesOrder[]
  quotations               Quotation[]
  salesReturns             SalesReturn[]
  purchaseReturns          PurchaseReturn[]
  chartOfAccounts          ChartOfAccount[]
  journalEntries           JournalEntry[]
  accountsReceivable       AccountsReceivable[]
  receivePayments          ReceivePayment[]
  accountsPayable          AccountsPayable[]
  supplierPayments         SupplierPayment[]
  cashAccounts             CashAccount[]
  bankAccounts             BankAccount[]
  invoices                 Invoice[]
  taxRates                 TaxRate[]
  companySettings          CompanySetting[]
  numberSequences          NumberSequence[]
  notesReceivable          NoteReceivable[]
  notesPayable             NotePayable[]
  departments              Department[]
  employees                Employee[]
  payrollPeriods           PayrollPeriod[]
  fixedAssets              FixedAsset[]
  fixedAssetDepreciations  FixedAssetDepreciation[]
  discountNotes            DiscountNote[]
  invoiceTracks            InvoiceTrack[]
  salaryStructures         SalaryStructure[]
  salaryChanges            SalaryChange[]
  licenseDevices           LicenseDevice[]
  licenseEvents            LicenseEvent[]
  posRegisters             PosRegister[]
  posShifts                PosShift[]
  posSales                 PosSale[]
  posRefunds               PosRefund[]
  posCashMovements         PosCashMovement[]
  posHeldSales             PosHeldSale[]
  posCartDrafts            PosCartDraft[]
  electronicInvoices       ElectronicInvoice[]
  electronicInvoiceEvents  ElectronicInvoiceEvent[]
  posPromotions            PosPromotion[]
  posCoupons               PosCoupon[]
  posCouponRedemptions     PosCouponRedemption[]
  posManagerApprovals      PosManagerApproval[]
  restaurantAreas          RestaurantArea[]
  restaurantTables         RestaurantTable[]
  restaurantOrders         RestaurantOrder[]
  restaurantKitchenTickets RestaurantKitchenTicket[]
  medicalServices           MedicalService[]
  medicalAppointments       MedicalAppointment[]
  medicalTreatmentPackages  MedicalTreatmentPackage[]
  medicalPackagePurchases   MedicalPackagePurchase[]
  medicalWallets            MedicalWallet[]
  medicalWalletTransactions MedicalWalletTransaction[]
  medicalConsents           MedicalConsent[]
  medicalTreatmentRecords   MedicalTreatmentRecord[]
  medicalReceipts           MedicalReceipt[]
  loyaltyTransactions      CustomerLoyaltyTransaction[]
  purchaseReceipts         PurchaseReceipt[]
  salesShipments           SalesShipment[]
  accountingPeriods        AccountingPeriod[]
  auditLogs                AuditLog[]
  offlineLease             OfflineLicenseLease?
  customColumnDefinitions  CustomColumnDefinition[]
  customFieldValues        CustomFieldValue[]
  planInquiries            PlanInquiry[]
  licensePayments          LicensePayment[]

  @@index([isInternal])
}

model CustomColumnDefinition {
  id        String             @id @default(cuid())
  tenantId  String
  module    String
  label     String
  type      String             @default("text")
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values    CustomFieldValue[]

  @@unique([tenantId, module, label])
  @@index([tenantId, module, sortOrder])
}

model CustomFieldValue {
  id        String                 @id @default(cuid())
  tenantId  String
  module    String
  rowId     String
  columnId  String
  value     String?
  updatedBy String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  column    CustomColumnDefinition @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module, rowId, columnId])
  @@index([tenantId, module, rowId])
  @@index([columnId])
}

// ─────────────────────────── 使用者 / 權限 (RBAC) ───────────────────────────
model User {
  id                String    @id @default(cuid())
  tenantId          String?
  username          String    @unique
  email             String    @unique
  name              String
  passwordHash      String
  isActive          Boolean   @default(true)
  isSuperAdmin      Boolean   @default(false)
  trialStart        DateTime  @default(now())
  isPaid            Boolean   @default(false)
  paymentType       String? // "ONCE" = 永久, "MONTHLY" = 月付
  subscriptionEnd   DateTime? // 月付到期日
  lastLoginAt       DateTime?
  lastLoginIp       String?
  registrationIp    String?
  createdByUserId   String? // 誰創建了這個用戶
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant         Tenant?        @relation(fields: [tenantId], references: [id])
  createdByUser  User?          @relation("UserCreator", fields: [createdByUserId], references: [id])
  createdUsers   User[]         @relation("UserCreator")
  userRoles      UserRole[]
  auditLogs      AuditLog[]
  loginLogs      LoginLog[]
  journalEntries JournalEntry[] @relation("JournalEntryCreator")

  @@index([tenantId])
  @@index([createdByUserId])
}

// 中央授權伺服器記錄已佔用席次。deviceHash 由伺服器密鑰 HMAC 後儲存，
// 不保存原始硬體識別碼。
model LicenseDevice {
  id              String    @id @default(cuid())
  tenantId        String
  deviceHash      String
  deviceRole      String    @default("WORKSTATION") // SERVER 或 WORKSTATION
  devicePublicKey String? // 工作站 Ed25519 SPKI DER base64；私鑰只留在 OS 安全儲存區
  displayName     String?
  platform        String?
  appVersion      String?
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  lastIp          String?
  revokedAt       DateTime?
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, deviceHash])
  @@index([tenantId, revokedAt])
  @@index([tenantId, deviceRole, revokedAt])
  @@index([lastSeenAt])
}

// 授權事件使用雜湊鏈簽章，能偵測日期、方案、席次與開通紀錄遭竄改。
model LicenseEvent {
  id           String   @id @default(cuid())
  tenantId     String
  action       String
  actorUserId  String?
  payload      Json?
  previousHash String
  eventHash    String   @unique
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

// 公開方案頁送出的聯絡需求。即使通知信暫時寄送失敗，管理後台仍能看見並追蹤。
model PlanInquiry {
  id                 String    @id @default(cuid())
  tenantId           String?
  name               String
  email              String
  company            String
  lineId             String?
  businessMode       String
  planCode           String
  billing            String
  notes              String?
  status             String    @default("NEW") // NEW / CONTACTED / CLOSED
  sourceIpHash       String?
  notificationStatus String    @default("PENDING") // PENDING / SENT / FAILED / NOT_CONFIGURED
  notificationError  String?
  notifiedAt         DateTime?
  contactedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email, createdAt])
  @@index([tenantId, createdAt])
}

// 人工核對付款後才建立；recordHash 涵蓋所有付款欄位，可由中央密鑰驗證是否遭修改。
model LicensePayment {
  id                String   @id
  tenantId          String
  planCode          String
  billing           String
  quotedAmount      Decimal  @db.Decimal(12, 2)
  paidAmount        Decimal  @db.Decimal(12, 2)
  paymentMethod     String
  paymentReference  String
  paidAt            DateTime
  confirmedByUserId String
  notes             String?
  recordHash        String   @unique
  createdAt         DateTime
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, paymentReference])
  @@index([tenantId, createdAt])
  @@index([paidAt])
}

// 本機安裝只保存中央伺服器簽發的短效租約；私鑰不會下放到客戶電腦。
model OfflineLicenseLease {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  remoteTenantId String
  payload        Json
  signature      String
  algorithm      String
  issuedAt       DateTime
  expiresAt      DateTime
  checkedAt      DateTime @default(now())
  lastObservedAt DateTime @default(now())
  lastError      String?
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  // 例: products.view / sales.create / accounting.approve
  code        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─────────────────────────── 商品 / 分類 / 單位 ───────────────────────────
model ProductCategory {
  id        String            @id @default(cuid())
  tenantId  String
  code      String
  name      String
  parentId  String?
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryTree")
  products  Product[]
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProductUnit {
  id       String    @id @default(cuid())
  tenantId String
  code     String
  name     String
  products Product[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  // 商品目錄依租戶營運模式隔離；保留舊模式商品供歷史單據引用。
  catalogMode String?
  sku         String
  barcode     String?
  name        String
  spec        String?
  description String?
  imageUrl    String?
  categoryId  String?
  unitId      String?
  costPrice   Decimal  @default(0) @db.Decimal(18, 4)
  salePrice   Decimal  @default(0) @db.Decimal(18, 4)
  safetyStock   Decimal  @default(0) @db.Decimal(18, 4)
  trackInventory Boolean  @default(true)
  taxRateId   String?
  isActive    Boolean  @default(true)
  isPublished Boolean  @default(true)
  isArchived  Boolean  @default(false)
  remark      String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant               Tenant                 @relation(fields: [tenantId], references: [id])
  category             ProductCategory?       @relation(fields: [categoryId], references: [id])
  unit                 ProductUnit?           @relation(fields: [unitId], references: [id])
  taxRate              TaxRate?               @relation(fields: [taxRateId], references: [id])
  stocks               InventoryStock[]
  txns                 InventoryTransaction[]
  purchaseItems        PurchaseOrderItem[]
  salesItems           SalesOrderItem[]
  quotationItems       QuotationItem[]
  salesReturnItems     SalesReturnItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  posSaleItems         PosSaleItem[]
  posRefundItems       PosRefundItem[]
  restaurantOrderItems RestaurantOrderItem[]
  medicalService       MedicalService?
  medicalPackage       MedicalTreatmentPackage?
  medicalConsumables   MedicalServiceConsumable[]
  purchaseReceiptItems PurchaseReceiptItem[]
  salesShipmentItems   SalesShipmentItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, catalogMode])
  @@index([tenantId, isArchived])
  @@index([tenantId, isActive])
  @@index([tenantId, isPublished])
}

// ─────────────────────────── 客戶 / 供應商 ───────────────────────────
model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  code         String
  companyName  String
  taxId        String?
  contactName  String?
  phone        String?
  email        String?
  address      String?
  paymentTerms String?
  creditLimit  Decimal  @default(0) @db.Decimal(18, 2)
  remark       String?
  isActive     Boolean  @default(true)
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant              Tenant                       @relation(fields: [tenantId], references: [id])
  salesOrders         SalesOrder[]
  quotations          Quotation[]
  receivables         AccountsReceivable[]
  receivePayments     ReceivePayment[]
  salesReturns        SalesReturn[]
  invoices            Invoice[]
  notes               NoteReceivable[]
  discountNotes       DiscountNote[]
  posSales            PosSale[]
  loyaltyPoints       Int                          @default(0)
  loyaltyTier         String                       @default("STANDARD")
  loyaltyTransactions CustomerLoyaltyTransaction[]
  couponRedemptions   PosCouponRedemption[]
  storefrontMember       StorefrontMember?
  medicalAppointments     MedicalAppointment[]
  medicalPackagePurchases MedicalPackagePurchase[]
  medicalWallet           MedicalWallet?
  medicalConsents         MedicalConsent[]
  medicalTreatmentRecords MedicalTreatmentRecord[]
  medicalReceipts         MedicalReceipt[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, isActive])
}

// 電商官網會員憑證與 ERP 客戶主檔分離保存；每位會員只屬於一個租戶。
model StorefrontMember {
  id              String                    @id @default(cuid())
  tenantId        String
  customerId      String                    @unique
  email           String
  passwordHash    String
  name            String
  phone           String?
  isActive        Boolean                   @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessions        StorefrontMemberSession[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
}

// 瀏覽器只保存隨機 Token；資料庫僅保存 SHA-256 雜湊，登出可立即撤銷。
model StorefrontMemberSession {
  id         String           @id @default(cuid())
  tenantId   String
  memberId   String
  tokenHash  String           @unique
  expiresAt  DateTime
  lastSeenAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member     StorefrontMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId, expiresAt])
  @@index([memberId, expiresAt])
}

enum StorefrontPaymentMethod {
  CARD
  MOBILE
  TRANSFER
}

enum StorefrontPaymentStatus {
  AWAITING_TRANSFER
  GATEWAY_REQUIRED
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
  EXPIRED
}

// 官網付款與銷售訂單分開記錄，日後串接金流回呼時可安全更新付款狀態。
model StorefrontPayment {
  id                String                  @id @default(cuid())
  tenantId          String
  orderId           String                  @unique
  method            StorefrontPaymentMethod
  status            StorefrontPaymentStatus
  amount            Decimal                 @db.Decimal(18, 2)
  refundedAmount    Decimal                 @default(0) @db.Decimal(18, 2)
  provider          String?
  providerReference String?
  expiresAt         DateTime?
  paidAt            DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order             SalesOrder              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, method, createdAt])
}

model Supplier {
  id           String   @id @default(cuid())
  tenantId     String
  code         String
  companyName  String
  taxId        String?
  contactName  String?
  phone        String?
  email        String?
  address      String?
  paymentTerms String?
  remark       String?
  isActive     Boolean  @default(true)
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  purchaseOrders   PurchaseOrder[]
  payables         AccountsPayable[]
  supplierPayments SupplierPayment[]
  purchaseReturns  PurchaseReturn[]
  invoices         Invoice[]
  notes            NotePayable[]
  discountNotes    DiscountNote[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, isActive])
}

// ─────────────────────────── 倉庫 / 庫存 ───────────────────────────
model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  stocks           InventoryStock[]
  txns             InventoryTransaction[]
  fromTransfers    StockTransfer[]        @relation("TransferFrom")
  toTransfers      StockTransfer[]        @relation("TransferTo")
  adjustments      StockAdjustment[]
  posRegisters     PosRegister[]
  posRefunds       PosRefund[]
  purchaseReceipts PurchaseReceipt[]
  salesShipments   SalesShipment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, isActive])
}

model InventoryStock {
  id          String    @id @default(cuid())
  tenantId    String
  productId   String
  warehouseId String
  quantity    Decimal   @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId])
}

enum InventoryTxnType {
  PURCHASE_IN
  SALES_OUT
  SALES_RETURN_IN
  PURCHASE_RETURN_OUT
  ADJUST_IN
  ADJUST_OUT
  TRANSFER_IN
  TRANSFER_OUT
  MANUAL
}

model InventoryTransaction {
  id          String           @id @default(cuid())
  tenantId    String
  productId   String
  warehouseId String
  type        InventoryTxnType
  quantity    Decimal          @db.Decimal(18, 4) // 正負數
  unitCost    Decimal?         @db.Decimal(18, 4)
  refType     String? // 例: PURCHASE / SALES / ADJUSTMENT / TRANSFER
  refId       String?
  remark      String?
  createdAt   DateTime         @default(now())
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  product     Product          @relation(fields: [productId], references: [id])
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, productId, createdAt])
  @@index([tenantId, warehouseId, createdAt])
  @@index([refType, refId])
}

model StockAdjustment {
  id          String                @id @default(cuid())
  tenantId    String
  number      String
  warehouseId String
  reason      String
  status      String                @default("DRAFT") // DRAFT / CONFIRMED
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id])
  items       StockAdjustmentItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, warehouseId])
}

model StockAdjustmentItem {
  id           String          @id @default(cuid())
  adjustmentId String
  productId    String
  systemQty    Decimal         @db.Decimal(18, 4)
  actualQty    Decimal         @db.Decimal(18, 4)
  diff         Decimal         @db.Decimal(18, 4)
  remark       String?
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
}

model StockTransfer {
  id              String              @id @default(cuid())
  tenantId        String
  number          String
  fromWarehouseId String
  toWarehouseId   String
  status          String              @default("DRAFT") // DRAFT / SHIPPED / RECEIVED
  remark          String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items           StockTransferItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, fromWarehouseId])
  @@index([tenantId, toWarehouseId])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Decimal       @db.Decimal(18, 4)
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

// ─────────────────────────── 採購 ───────────────────────────
enum PurchaseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  POSTED
  VOIDED
  REJECTED
}

model PurchaseOrder {
  id           String         @id @default(cuid())
  tenantId     String
  number       String
  supplierId   String
  warehouseId  String?
  orderDate    DateTime       @default(now())
  expectedDate DateTime?
  status       PurchaseStatus @default(DRAFT)
  subtotal     Decimal        @default(0) @db.Decimal(18, 2)
  discount     Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount    Decimal        @default(0) @db.Decimal(18, 2)
  total        Decimal        @default(0) @db.Decimal(18, 2)
  isTaxable    Boolean        @default(true)
  remark       String?
  receivedAt   DateTime?
  updatedBy    String?
