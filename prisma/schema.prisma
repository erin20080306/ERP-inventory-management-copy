  type        String   @default("SALES") // SALES / PURCHASE
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year, period, trackCode, type])
  @@index([tenantId])
}

