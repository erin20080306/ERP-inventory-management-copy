// ─────────────────────────── 會計 ───────────────────────────
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST
  EXPENSE
}

model ChartOfAccount {
  id             String             @id @default(cuid())
  tenantId       String
  code           String
  name           String
  type           AccountType
  parentId       String?
  openingBalance Decimal            @default(0) @db.Decimal(18, 2)
  isActive       Boolean            @default(true)
  updatedBy      String?
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
