// ─────────────────────────── 銷售 ───────────────────────────
enum SalesStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_SHIPPED
  POSTED
  VOIDED
  REJECTED
}

model SalesOrder {
  id          String      @id @default(cuid())
  tenantId    String
  number      String
  customerId  String
  warehouseId String?
  orderDate   DateTime    @default(now())
  status      SalesStatus @default(DRAFT)
  subtotal    Decimal     @default(0) @db.Decimal(18, 2)
  discount    Decimal     @default(0) @db.Decimal(18, 2)
