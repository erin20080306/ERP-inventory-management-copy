// 專業 ERP 進銷存會計管理系統 - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── 使用者 / 權限 (RBAC) ───────────────────────────
model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  name         String
  passwordHash String
  isActive     Boolean   @default(true)
  trialStart   DateTime  @default(now())
  isPaid       Boolean   @default(false)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userRoles      UserRole[]
  auditLogs      AuditLog[]
  loginLogs      LoginLog[]
  journalEntries JournalEntry[] @relation("JournalEntryCreator")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  // 例: products.view / sales.create / accounting.approve
  code        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─────────────────────────── 商品 / 分類 / 單位 ───────────────────────────
model ProductCategory {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  parentId  String?
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ProductUnit {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  barcode     String?  @unique
  name        String
  spec        String?
  description String?
  imageUrl    String?
  categoryId  String?
  unitId      String?
  costPrice   Decimal  @default(0) @db.Decimal(18, 4)
  salePrice   Decimal  @default(0) @db.Decimal(18, 4)
  safetyStock Decimal  @default(0) @db.Decimal(18, 4)
  taxRateId   String?
  isActive    Boolean  @default(true)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category            ProductCategory?       @relation(fields: [categoryId], references: [id])
  unit                ProductUnit?           @relation(fields: [unitId], references: [id])
  taxRate             TaxRate?               @relation(fields: [taxRateId], references: [id])
  stocks              InventoryStock[]
  txns                InventoryTransaction[]
  purchaseItems       PurchaseOrderItem[]
  salesItems          SalesOrderItem[]
  quotationItems      QuotationItem[]
  salesReturnItems    SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
}

// ─────────────────────────── 客戶 / 供應商 ───────────────────────────
model Customer {
  id           String   @id @default(cuid())
  code         String   @unique
  companyName  String
  taxId        String?
  contactName  String?
  phone        String?
  email        String?
  address      String?
  paymentTerms String?
  creditLimit  Decimal  @default(0) @db.Decimal(18, 2)
  remark       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrders     SalesOrder[]
  quotations      Quotation[]
  receivables     AccountsReceivable[]
  receivePayments ReceivePayment[]
  salesReturns    SalesReturn[]
  invoices        Invoice[]
  notes           NoteReceivable[]
}

model Supplier {
  id           String   @id @default(cuid())
  code         String   @unique
  companyName  String
  taxId        String?
  contactName  String?
  phone        String?
  email        String?
  address      String?
  paymentTerms String?
  remark       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  payables         AccountsPayable[]
  supplierPayments SupplierPayment[]
  purchaseReturns  PurchaseReturn[]
  invoices         Invoice[]
  notes            NotePayable[]
}

// ─────────────────────────── 倉庫 / 庫存 ───────────────────────────
model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks        InventoryStock[]
  txns          InventoryTransaction[]
  fromTransfers StockTransfer[]        @relation("TransferFrom")
  toTransfers   StockTransfer[]        @relation("TransferTo")
  adjustments   StockAdjustment[]
}

model InventoryStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Decimal   @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

enum InventoryTxnType {
  PURCHASE_IN
  SALES_OUT
  SALES_RETURN_IN
  PURCHASE_RETURN_OUT
  ADJUST_IN
  ADJUST_OUT
  TRANSFER_IN
  TRANSFER_OUT
  MANUAL
}

model InventoryTransaction {
  id          String           @id @default(cuid())
  productId   String
  warehouseId String
  type        InventoryTxnType
  quantity    Decimal          @db.Decimal(18, 4) // 正負數
  unitCost    Decimal?         @db.Decimal(18, 4)
  refType     String? // 例: PURCHASE / SALES / ADJUSTMENT / TRANSFER
  refId       String?
  remark      String?
  createdAt   DateTime         @default(now())
  product     Product          @relation(fields: [productId], references: [id])
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([refType, refId])
}

model StockAdjustment {
  id          String                @id @default(cuid())
  number      String                @unique
  warehouseId String
  reason      String
  status      String                @default("DRAFT") // DRAFT / CONFIRMED
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id])
  items       StockAdjustmentItem[]
}

model StockAdjustmentItem {
  id           String          @id @default(cuid())
  adjustmentId String
  productId    String
  systemQty    Decimal         @db.Decimal(18, 4)
  actualQty    Decimal         @db.Decimal(18, 4)
  diff         Decimal         @db.Decimal(18, 4)
  remark       String?
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
}

model StockTransfer {
  id              String              @id @default(cuid())
  number          String              @unique
  fromWarehouseId String
  toWarehouseId   String
  status          String              @default("DRAFT") // DRAFT / SHIPPED / RECEIVED
  remark          String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items           StockTransferItem[]
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Decimal       @db.Decimal(18, 4)
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

// ─────────────────────────── 採購 ───────────────────────────
enum PurchaseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String         @id @default(cuid())
  number       String         @unique
  supplierId   String
  warehouseId  String?
  orderDate    DateTime       @default(now())
  expectedDate DateTime?
  status       PurchaseStatus @default(DRAFT)
  subtotal     Decimal        @default(0) @db.Decimal(18, 2)
  discount     Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount    Decimal        @default(0) @db.Decimal(18, 2)
  total        Decimal        @default(0) @db.Decimal(18, 2)
  remark       String?
  receivedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  payables AccountsPayable[]
  returns  PurchaseReturn[]
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  orderId     String
  productId   String
  quantity    Decimal       @db.Decimal(18, 4)
  receivedQty Decimal       @default(0) @db.Decimal(18, 4)
  unitPrice   Decimal       @db.Decimal(18, 4)
  discount    Decimal       @default(0) @db.Decimal(18, 2)
  taxRate     Decimal       @default(0) @db.Decimal(6, 4)
  subtotal    Decimal       @db.Decimal(18, 2)
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id])
}

// ─────────────────────────── 銷售 ───────────────────────────
enum SalesStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  INVOICED
  PAID
  CANCELLED
}

model SalesOrder {
  id          String      @id @default(cuid())
  number      String      @unique
  customerId  String
  warehouseId String?
  orderDate   DateTime    @default(now())
  status      SalesStatus @default(DRAFT)
  subtotal    Decimal     @default(0) @db.Decimal(18, 2)
  discount    Decimal     @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal     @default(0) @db.Decimal(18, 2)
  total       Decimal     @default(0) @db.Decimal(18, 2)
  remark      String?
  shippedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer    Customer             @relation(fields: [customerId], references: [id])
  items       SalesOrderItem[]
  receivables AccountsReceivable[]
  returns     SalesReturn[]
}

model SalesOrderItem {
  id         String     @id @default(cuid())
  orderId    String
  productId  String
  quantity   Decimal    @db.Decimal(18, 4)
  shippedQty Decimal    @default(0) @db.Decimal(18, 4)
  unitPrice  Decimal    @db.Decimal(18, 4)
  discount   Decimal    @default(0) @db.Decimal(18, 2)
  taxRate    Decimal    @default(0) @db.Decimal(6, 4)
  subtotal   Decimal    @db.Decimal(18, 2)
  order      SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
}

// ─────────────────────────── 報價單 ───────────────────────────
enum QuotationStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id         String          @id @default(cuid())
  number     String          @unique
  customerId String
  quoteDate  DateTime        @default(now())
  validUntil DateTime?
  status     QuotationStatus @default(DRAFT)
  subtotal   Decimal         @default(0) @db.Decimal(18, 2)
  discount   Decimal         @default(0) @db.Decimal(18, 2)
  taxAmount  Decimal         @default(0) @db.Decimal(18, 2)
  total      Decimal         @default(0) @db.Decimal(18, 2)
  remark     String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  customer   Customer        @relation(fields: [customerId], references: [id])
  items      QuotationItem[]
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  productId   String
  quantity    Decimal   @db.Decimal(18, 4)
  unitPrice   Decimal   @db.Decimal(18, 4)
  discount    Decimal   @default(0) @db.Decimal(18, 2)
  taxRate     Decimal   @default(0) @db.Decimal(6, 4)
  subtotal    Decimal   @db.Decimal(18, 2)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
}

// ─────────────────────────── 退貨 ───────────────────────────
model SalesReturn {
  id           String            @id @default(cuid())
  number       String            @unique
  customerId   String
  salesOrderId String?
  returnDate   DateTime          @default(now())
  reason       String?
  status       String            @default("DRAFT") // DRAFT / CONFIRMED
  total        Decimal           @default(0) @db.Decimal(18, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  customer     Customer          @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  items        SalesReturnItem[]
}

model SalesReturnItem {
  id        String      @id @default(cuid())
  returnId  String
  productId String
  quantity  Decimal     @db.Decimal(18, 4)
  unitPrice Decimal     @db.Decimal(18, 4)
  subtotal  Decimal     @db.Decimal(18, 2)
  return    SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id])
}

model PurchaseReturn {
  id              String               @id @default(cuid())
  number          String               @unique
  supplierId      String
  purchaseOrderId String?
  returnDate      DateTime             @default(now())
  reason          String?
  status          String               @default("DRAFT")
  total           Decimal              @default(0) @db.Decimal(18, 2)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  purchaseOrder   PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  items           PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id        String         @id @default(cuid())
  returnId  String
  productId String
  quantity  Decimal        @db.Decimal(18, 4)
  unitPrice Decimal        @db.Decimal(18, 4)
  subtotal  Decimal        @db.Decimal(18, 2)
  return    PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
}

// ─────────────────────────── 會計 ───────────────────────────
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST
  EXPENSE
}

model ChartOfAccount {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String
  type           AccountType
  parentId       String?
  openingBalance Decimal            @default(0) @db.Decimal(18, 2)
  isActive       Boolean            @default(true)
  parent         ChartOfAccount?    @relation("AccountTree", fields: [parentId], references: [id])
  children       ChartOfAccount[]   @relation("AccountTree")
  lines          JournalEntryLine[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

model JournalEntry {
  id          String             @id @default(cuid())
  number      String             @unique
  entryDate   DateTime           @default(now())
  summary     String
  status      JournalStatus      @default(DRAFT)
  attachment  String?
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User?              @relation("JournalEntryCreator", fields: [createdById], references: [id])
  lines       JournalEntryLine[]
}

model JournalEntryLine {
  id        String         @id @default(cuid())
  entryId   String
  accountId String
  debit     Decimal        @default(0) @db.Decimal(18, 2)
  credit    Decimal        @default(0) @db.Decimal(18, 2)
  memo      String?
  entry     JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account   ChartOfAccount @relation(fields: [accountId], references: [id])
}

model AccountsReceivable {
  id           String           @id @default(cuid())
  customerId   String
  salesOrderId String?
  invoiceId    String?
  amount       Decimal          @db.Decimal(18, 2)
  paidAmount   Decimal          @default(0) @db.Decimal(18, 2)
  dueDate      DateTime?
  status       String           @default("OPEN") // OPEN / PARTIAL / PAID / OVERDUE
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  customer     Customer         @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  payments     ReceivePayment[]
  notes        NoteReceivable[]
}

model ReceivePayment {
  id            String              @id @default(cuid())
  number        String              @unique
  customerId    String
  receivableId  String?
  paymentDate   DateTime            @default(now())
  amount        Decimal             @db.Decimal(18, 2)
  method        String // CASH / BANK / CHEQUE
  bankAccountId String?
  cashAccountId String?
  remark        String?
  createdAt     DateTime            @default(now())
  customer      Customer            @relation(fields: [customerId], references: [id])
  receivable    AccountsReceivable? @relation(fields: [receivableId], references: [id])
}

model AccountsPayable {
  id              String            @id @default(cuid())
  supplierId      String
  purchaseOrderId String?
  invoiceId       String?
  amount          Decimal           @db.Decimal(18, 2)
  paidAmount      Decimal           @default(0) @db.Decimal(18, 2)
  dueDate         DateTime?
  status          String            @default("OPEN")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  supplier        Supplier          @relation(fields: [supplierId], references: [id])
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  payments        SupplierPayment[]
  notes           NotePayable[]
}

model SupplierPayment {
  id            String           @id @default(cuid())
  number        String           @unique
  supplierId    String
  payableId     String?
  paymentDate   DateTime         @default(now())
  amount        Decimal          @db.Decimal(18, 2)
  method        String
  bankAccountId String?
  cashAccountId String?
  remark        String?
  createdAt     DateTime         @default(now())
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  payable       AccountsPayable? @relation(fields: [payableId], references: [id])
}

// ─────────────────────────── 現金 / 銀行 ───────────────────────────
model CashAccount {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  balance   Decimal           @default(0) @db.Decimal(18, 2)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  txns      CashTransaction[]
}

enum BankAccountType {
  CHECKING // 甲存（支票存款）
  SAVINGS // 乙存（活期存款）
  TIME_DEPOSIT // 定期存款
  FOREIGN // 外幣存款
}

model BankAccount {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  bankName      String?
  accountNumber String?
  accountType   BankAccountType   @default(SAVINGS)
  branchName    String?
  swift         String?
  balance       Decimal           @default(0) @db.Decimal(18, 2)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  txns          BankTransaction[]
  notesPayable  NotePayable[]
}

model CashTransaction {
  id            String      @id @default(cuid())
  cashAccountId String
  type          String // IN / OUT / TRANSFER
  amount        Decimal     @db.Decimal(18, 2)
  txnDate       DateTime    @default(now())
  remark        String?
  account       CashAccount @relation(fields: [cashAccountId], references: [id])
}

model BankTransaction {
  id            String      @id @default(cuid())
  bankAccountId String
  type          String
  amount        Decimal     @db.Decimal(18, 2)
  txnDate       DateTime    @default(now())
  remark        String?
  reconciled    Boolean     @default(false)
  account       BankAccount @relation(fields: [bankAccountId], references: [id])
}

// ─────────────────────────── 發票 / 稅務 ───────────────────────────
enum InvoiceType {
  SALES
  PURCHASE
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  type        InvoiceType
  invoiceDate DateTime      @default(now())
  customerId  String?
  supplierId  String?
  amountExTax Decimal       @db.Decimal(18, 2)
  taxAmount   Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount Decimal       @db.Decimal(18, 2)
  status      String        @default("ISSUED") // ISSUED / VOID
  remark      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  customer    Customer?     @relation(fields: [customerId], references: [id])
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  items       InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 4)
  taxRate     Decimal @default(0) @db.Decimal(6, 4)
  subtotal    Decimal @db.Decimal(18, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model TaxRate {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  rate     Decimal   @db.Decimal(6, 4) // 例 0.05
  region   String?
  isActive Boolean   @default(true)
  products Product[]
}

// ─────────────────────────── 系統 / 公司 / Log / 編號 ───────────────────────────
model CompanySetting {
  id        String   @id @default(cuid())
  name      String
  taxId     String?
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  currency  String   @default("TWD")
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key   String @id
  value String
}

model NumberSequence {
  key       String   @id // 例: SO / PO / JE / QT / RP / SP / SR / PR / ADJ / TRF
  prefix    String   @default("")
  nextNo    Int      @default(1)
  format    String   @default("{prefix}{yyyy}{mm}-{seq:0000}")
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  module    String
  refId     String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([userId])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

// ─────────────────────────── 票據管理 ───────────────────────────
enum NoteStatus {
  PENDING // 未到期
  CLEARED // 已兌現
  BOUNCED // 退票
  ENDORSED // 已背書轉讓
  VOID // 作廢
}

enum NoteType {
  CHECK // 支票
  PROMISSORY // 本票
  DRAFT // 匯票
  OTHER
}

/// 應收票據 (客戶開立或背書轉讓給本公司之票據)
model NoteReceivable {
  id           String              @id @default(cuid())
  number       String              @unique // 系統編號 NR-yyyymm-xxxx
  noteNumber   String // 票號
  noteType     NoteType            @default(CHECK)
  customerId   String
  bankName     String? // 付款銀行
  branchName   String? // 分行
  drawerName   String? // 發票人
  amount       Decimal             @db.Decimal(18, 2)
  issueDate    DateTime            @default(now()) // 票面日期
  dueDate      DateTime // 到期日 / 兌現日
  status       NoteStatus          @default(PENDING)
  clearedDate  DateTime?
  receivableId String? // 關聯之應收帳款
  remark       String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  customer     Customer            @relation(fields: [customerId], references: [id])
  receivable   AccountsReceivable? @relation(fields: [receivableId], references: [id])

  @@index([dueDate])
  @@index([status])
}

/// 應付票據 (本公司開立給供應商之票據)
model NotePayable {
  id            String           @id @default(cuid())
  number        String           @unique // 系統編號 NP-yyyymm-xxxx
  noteNumber    String // 票號
  noteType      NoteType         @default(CHECK)
  supplierId    String
  bankAccountId String? // 開立支票之銀行帳戶 (甲存)
  payeeName     String? // 抬頭
  amount        Decimal          @db.Decimal(18, 2)
  issueDate     DateTime         @default(now())
  dueDate       DateTime
  status        NoteStatus       @default(PENDING)
  clearedDate   DateTime?
  payableId     String?
  remark        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  bankAccount   BankAccount?     @relation(fields: [bankAccountId], references: [id])
  payable       AccountsPayable? @relation(fields: [payableId], references: [id])

  @@index([dueDate])
  @@index([status])
}

// ─────────────────────────── 人事 / 薪資 ───────────────────────────
enum EmployeeStatus {
  ACTIVE // 在職
  PROBATION // 試用期
  ON_LEAVE // 留職停薪
  RESIGNED // 離職
  RETIRED // 退休
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Department {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  parentId  String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  parent    Department?  @relation("DeptParent", fields: [parentId], references: [id])
  children  Department[] @relation("DeptParent")
  employees Employee[]
}

model Employee {
  id                   String             @id @default(cuid())
  employeeNo           String             @unique // 員工編號 e.g. EMP001
  name                 String
  englishName          String?
  idNumber             String?            @unique // 身分證字號
  gender               Gender?
  birthDate            DateTime?
  phone                String?
  email                String?
  address              String?
  emergencyContact     String?
  emergencyPhone       String?
  // 任職資訊
  departmentId         String?
  position             String? // 職稱
  hireDate             DateTime
  resignDate           DateTime?
  status               EmployeeStatus     @default(ACTIVE)
  // 薪資設定
  baseSalary           Decimal            @default(0) @db.Decimal(18, 2) // 本薪
  mealAllowance        Decimal            @default(2400) @db.Decimal(18, 2) // 伙食津貼(免稅)
  transportAllowance   Decimal            @default(0) @db.Decimal(18, 2)
  positionAllowance    Decimal            @default(0) @db.Decimal(18, 2)
  // 投保資訊
  insuredSalary        Decimal            @default(0) @db.Decimal(18, 2) // 投保薪資
  laborPensionRate     Decimal            @default(0.06) @db.Decimal(6, 4) // 雇主提繳率 (預設6%)
  voluntaryPensionRate Decimal            @default(0) @db.Decimal(6, 4) // 員工自願提繳
  dependents           Int                @default(0) // 健保眷屬數
  // 銀行帳戶
  bankName             String?
  bankAccountNo        String?
  taxId                String? // 所得稅扣繳憑單統編
  remark               String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  department           Department?        @relation(fields: [departmentId], references: [id])
  payrolls             Payroll[]
  attendances          AttendanceRecord[]

  @@index([status])
  @@index([departmentId])
}

enum PayrollStatus {
  DRAFT // 草稿
  CONFIRMED // 已確認
  PAID // 已發放
  VOID // 作廢
}

/// 薪資結算期間 (月份)
model PayrollPeriod {
  id          String        @id @default(cuid())
  year        Int // 西元年
  month       Int // 月份 1-12
  periodStart DateTime
  periodEnd   DateTime
  payDate     DateTime? // 預定/實際發薪日
  status      PayrollStatus @default(DRAFT)
  remark      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payrolls    Payroll[]

  @@unique([year, month])
}

/// 個別員工薪資單
model Payroll {
  id            String        @id @default(cuid())
  number        String        @unique // 薪資單號 e.g. PR-202601-0001
  periodId      String
  employeeId    String
  // 出勤資料
  workDays      Decimal       @default(0) @db.Decimal(6, 2)
  leaveDays     Decimal       @default(0) @db.Decimal(6, 2)
  overtimeHours Decimal       @default(0) @db.Decimal(6, 2)
  // 應發小計
  earnings      Decimal       @default(0) @db.Decimal(18, 2)
  // 應扣小計
  deductions    Decimal       @default(0) @db.Decimal(18, 2)
  // 雇主負擔(不影響淨額，但企業成本)
  employerCost  Decimal       @default(0) @db.Decimal(18, 2)
  // 淨額
  netPay        Decimal       @default(0) @db.Decimal(18, 2)
  status        PayrollStatus @default(DRAFT)
  paidAt        DateTime?
  remark        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  period        PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id])
  items         PayrollItem[]

  @@unique([periodId, employeeId])
  @@index([status])
}

enum PayrollItemType {
  EARNING // 應發 (本薪、加班費、獎金、津貼)
  DEDUCTION // 應扣 (勞健保、所得稅、借支)
  EMPLOYER // 雇主負擔 (勞退、勞健保雇主部分)
}

model PayrollItem {
  id        String          @id @default(cuid())
  payrollId String
  type      PayrollItemType
  code      String // 項目代碼 BASE / OT / NHI / LI / TAX ...
  name      String // 中文項目名稱
  amount    Decimal         @db.Decimal(18, 2)
  taxable   Boolean         @default(true) // 是否計入所得稅
  remark    String?
  payroll   Payroll         @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([code])
}

/// 出勤紀錄 (簡化版)
enum AttendanceType {
  WORK // 上班
  ANNUAL_LEAVE // 特休
  SICK_LEAVE // 病假
  PERSONAL // 事假
  FUNERAL // 喪假
  MATERNITY // 產假
  PATERNITY // 陪產假
  PUBLIC // 公假
  ABSENT // 曠職
  OVERTIME // 加班
}

model AttendanceRecord {
  id         String         @id @default(cuid())
  employeeId String
  date       DateTime
  type       AttendanceType
  hours      Decimal        @default(8) @db.Decimal(6, 2)
  remark     String?
  createdAt  DateTime       @default(now())
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@index([date])
}

// ─────────────────────────── 固定資產 ───────────────────────────
enum DepreciationMethod {
  STRAIGHT_LINE // 直線法
  DOUBLE_DECLINING // 倍數餘額遞減
  SUM_OF_YEARS // 年數合計
  NONE
}

enum FixedAssetStatus {
  IN_USE // 使用中
  IDLE // 閒置
  DISPOSED // 已處分
  IMPAIRED // 減損
}

/// 固定資產目錄
model FixedAsset {
  id                      String             @id @default(cuid())
  code                    String             @unique // 資產編號
  name                    String // 資產名稱
  category                String? // 分類 (土地/建築/設備...)
  accountCode             String? // 對應會計科目代碼 (1401, 1421...)
  acquireDate             DateTime // 取得日
  acquireCost             Decimal            @db.Decimal(18, 2)
  residualValue           Decimal            @default(0) @db.Decimal(18, 2)
  usefulLifeMonths        Int                @default(60) // 耐用年限(月)
  method                  DepreciationMethod @default(STRAIGHT_LINE)
  accumulatedDepreciation Decimal            @default(0) @db.Decimal(18, 2)
  bookValue               Decimal            @db.Decimal(18, 2)
  location                String?
  serialNumber            String?
  supplierId              String?
  status                  FixedAssetStatus   @default(IN_USE)
  disposeDate             DateTime?
  disposeAmount           Decimal?           @db.Decimal(18, 2)
  remark                  String?
  sourceJournalId         String? // 來源傳票 (若由傳票自動建立)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([category])
  @@index([status])
}
