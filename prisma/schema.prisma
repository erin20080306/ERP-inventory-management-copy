// ─────────────────────────── 發票字軌管理 ───────────────────────────
model InvoiceTrack {
  id          String   @id @default(cuid())
  tenantId    String
  year        Int // 民國年，例 114
  period      Int // 期別 1~6（1-2月=1, 3-4月=2, ...）
