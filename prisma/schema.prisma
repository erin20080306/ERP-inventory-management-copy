  id                         String   @id @default(cuid())
  tenantId                   String
  name                       String
  taxId                      String?
  address                    String?
  phone                      String?
  email                      String?
  logoUrl                    String?
  currency                   String   @default("TWD")
  storeName                  String?
  storeSlug                  String?  @unique
  storeTransferBankName      String?
  storeTransferAccountName   String?
  storeTransferAccountNumber String?
  smtpHost                   String?
  smtpPort                   Int?
  smtpSecure                 Boolean  @default(true)
  smtpUser                   String?
  smtpPassword               String?
  smtpFromName               String?
  smtpFromEmail              String?
  updatedAt                  DateTime @updatedAt
  tenant                     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model SystemSetting {
  key   String @id
  value String
}

model NumberSequence {
  id        String   @id @default(cuid())
  tenantId  String
  key       String // 例: SO / PO / JE / QT / RP / SP / SR / PR / ADJ / TRF
  prefix    String   @default("")
  nextNo    Int      @default(1)
  format    String   @default("{prefix}{yyyy}{mm}-{seq:0000}")
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
}

model AuditLog {
  id               String   @id @default(cuid())
  tenantId         String?
  userId           String?
  action           String
  module           String
  refId            String?
  detail           String?
  ip               String?
  previousHash     String?
  entryHash        String?  @unique
  integrityVersion Int      @default(1)
  createdAt        DateTime @default(now())
  tenant           Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([userId])
  @@index([tenantId, createdAt])
}

model PermissionChangeLog {
  id             String   @id @default(cuid())
  userId         String?
  roleId         String
  roleName       String?
  action         String
  oldValue       String?
  newValue       String?
  permissionCode String?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([roleId])
  @@index([userId])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model ErrorLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  method    String?
  path      String?
  status    Int      @default(500)
  message   String
  stack     String?
  ip        String?
  userAgent String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

// ─────────────────────────── 票據管理 ───────────────────────────
enum NoteStatus {
  DRAFT
  SUBMITTED
  APPROVED
  POSTED
  VOIDED
  REJECTED
}

enum NoteType {
  CHECK // 支票
  PROMISSORY // 本票
  DRAFT // 匯票
  OTHER
}

/// 應收票據 (客戶開立或背書轉讓給本公司之票據)
model NoteReceivable {
  id           String              @id @default(cuid())
  tenantId     String
  number       String // 系統編號 NR-yyyymm-xxxx
  noteNumber   String // 票號
  noteType     NoteType            @default(CHECK)
  customerId   String
  bankName     String? // 付款銀行
  branchName   String? // 分行
  drawerName   String? // 發票人
  amount       Decimal             @db.Decimal(18, 2)
  issueDate    DateTime            @default(now()) // 票面日期
  dueDate      DateTime // 到期日 / 兌現日
  status       NoteStatus          @default(DRAFT)
  clearedDate  DateTime?
  receivableId String? // 關聯之應收帳款
  remark       String?
  updatedBy    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  customer     Customer            @relation(fields: [customerId], references: [id])
  receivable   AccountsReceivable? @relation(fields: [receivableId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([dueDate])
  @@index([status])
}

/// 應付票據 (本公司開立給供應商之票據)
model NotePayable {
  id            String           @id @default(cuid())
  tenantId      String
  number        String // 系統編號 NP-yyyymm-xxxx
  noteNumber    String // 票號
  noteType      NoteType         @default(CHECK)
  supplierId    String
  bankAccountId String? // 開立支票之銀行帳戶 (甲存)
  payeeName     String? // 抬頭
  amount        Decimal          @db.Decimal(18, 2)
  issueDate     DateTime         @default(now())
  dueDate       DateTime
  status        NoteStatus       @default(DRAFT)
  clearedDate   DateTime?
  payableId     String?
  remark        String?
  updatedBy     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  bankAccount   BankAccount?     @relation(fields: [bankAccountId], references: [id])
  payable       AccountsPayable? @relation(fields: [payableId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([dueDate])
  @@index([status])
}

// ─────────────────────────── 人事 / 薪資 ───────────────────────────
enum EmployeeStatus {
  ACTIVE // 在職
  PROBATION // 試用期
  ON_LEAVE // 留職停薪
  RESIGNED // 離職
  RETIRED // 退休
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Department {
  id        String       @id @default(cuid())
  tenantId  String
  code      String
  name      String
  parentId  String?
  isActive  Boolean      @default(true)
  updatedBy String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  parent    Department?  @relation("DeptParent", fields: [parentId], references: [id])
  children  Department[] @relation("DeptParent")
  employees Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Employee {
  id                   String                    @id @default(cuid())
  tenantId             String
  employeeNo           String // 員工編號 e.g. EMP001
  name                 String
  englishName          String?
  idNumber             String? // 身分證字號
  gender               Gender?
  birthDate            DateTime?
  phone                String?
  email                String?
  address              String?
  emergencyContact     String?
  emergencyPhone       String?
  // 任職資訊
  departmentId         String?
  position             String? // 職稱
  hireDate             DateTime
  resignDate           DateTime?
  status               EmployeeStatus            @default(ACTIVE)
  // 薪資設定
  baseSalary           Decimal                   @default(0) @db.Decimal(18, 2) // 本薪
  mealAllowance        Decimal                   @default(2400) @db.Decimal(18, 2) // 伙食津貼(免稅)
  transportAllowance   Decimal                   @default(0) @db.Decimal(18, 2)
  positionAllowance    Decimal                   @default(0) @db.Decimal(18, 2)
  // 投保資訊
  insuredSalary        Decimal                   @default(0) @db.Decimal(18, 2) // 投保薪資
  laborPensionRate     Decimal                   @default(0.06) @db.Decimal(6, 4) // 雇主提繳率 (預設6%)
  voluntaryPensionRate Decimal                   @default(0) @db.Decimal(6, 4) // 員工自願提繳
  dependents           Int                       @default(0) // 健保眷屬數
  // 銀行帳戶
  bankName             String?
  bankAccountNo        String?
  taxId                String? // 所得稅扣繳憑單統編
  remark               String?
  updatedBy            String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  tenant               Tenant                    @relation(fields: [tenantId], references: [id])
  department           Department?               @relation(fields: [departmentId], references: [id])
  payrolls             Payroll[]
  attendances          AttendanceRecord[]
  salaryStructures     EmployeeSalaryStructure[]
  salaryChanges        SalaryChange[]

  @@unique([tenantId, employeeNo])
  @@index([tenantId])
  @@index([status])
  @@index([departmentId])
}

enum PayrollStatus {
  DRAFT // 草稿
  CONFIRMED // 已確認
  PAID // 已發放
  VOID // 作廢
}

/// 薪資結算期間 (月份)
model PayrollPeriod {
  id          String        @id @default(cuid())
  tenantId    String
  year        Int // 西元年
  month       Int // 月份 1-12
  periodStart DateTime
  periodEnd   DateTime
  payDate     DateTime? // 預定/實際發薪日
  status      PayrollStatus @default(DRAFT)
  remark      String?
  updatedBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  payrolls    Payroll[]

  @@unique([tenantId, year, month])
  @@index([tenantId])
}

/// 個別員工薪資單
model Payroll {
  id            String        @id @default(cuid())
  number        String        @unique // 薪資單號 e.g. PR-202601-0001
  periodId      String
  employeeId    String
  // 出勤資料
  workDays      Decimal       @default(0) @db.Decimal(6, 2)
  leaveDays     Decimal       @default(0) @db.Decimal(6, 2)
  overtimeHours Decimal       @default(0) @db.Decimal(6, 2)
  // 應發小計
  earnings      Decimal       @default(0) @db.Decimal(18, 2)
  // 應扣小計
  deductions    Decimal       @default(0) @db.Decimal(18, 2)
  // 雇主負擔(不影響淨額，但企業成本)
  employerCost  Decimal       @default(0) @db.Decimal(18, 2)
  // 淨額
  netPay        Decimal       @default(0) @db.Decimal(18, 2)
  status        PayrollStatus @default(DRAFT)
  paidAt        DateTime?
  remark        String?
  updatedBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  period        PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id])
  items         PayrollItem[]

  @@unique([periodId, employeeId])
  @@index([status])
}

enum PayrollItemType {
  EARNING // 應發 (本薪、加班費、獎金、津貼)
  DEDUCTION // 應扣 (勞健保、所得稅、借支)
  EMPLOYER // 雇主負擔 (勞退、勞健保雇主部分)
}

model PayrollItem {
  id        String          @id @default(cuid())
  payrollId String
  type      PayrollItemType
  code      String // 項目代碼 BASE / OT / NHI / LI / TAX ...
  name      String // 中文項目名稱
  amount    Decimal         @db.Decimal(18, 2)
  taxable   Boolean         @default(true) // 是否計入所得稅
  remark    String?
  payroll   Payroll         @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([code])
}

/// 出勤紀錄 (簡化版)
enum AttendanceType {
  WORK // 上班
  ANNUAL_LEAVE // 特休
  SICK_LEAVE // 病假
  PERSONAL // 事假
  FUNERAL // 喪假
  MATERNITY // 產假
  PATERNITY // 陪產假
  PUBLIC // 公假
  ABSENT // 曠職
  OVERTIME // 加班
}

model AttendanceRecord {
  id         String         @id @default(cuid())
  employeeId String
  date       DateTime
  type       AttendanceType
  hours      Decimal        @default(8) @db.Decimal(6, 2)
  remark     String?
  createdAt  DateTime       @default(now())
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@index([date])
}

// ─────────────────────────── 薪資結構設計 ───────────────────────────
enum SalaryStructureType {
  BASE // 底薪
  PERFORMANCE // 績效獎金
  OVERTIME // 加班費
  ALLOWANCE // 津貼
  BONUS // 獎金
  COMMISSION // 佣金
  DEDUCTION // 扣款
}

enum SalaryCalculationMethod {
  FIXED // 固定金額
  PERCENTAGE // 百分比
  HOURLY // 時薪
  DAILY // 日薪
  MONTHLY // 月薪
}

/// 薪資結構模板
model SalaryStructure {
  id                 String                    @id @default(cuid())
  tenantId           String
  code               String // 結構代碼 e.g. SAL-001
  name               String // 結構名稱 e.g. 標準薪資結構
  type               SalaryStructureType
  calculationMethod  SalaryCalculationMethod
  amount             Decimal                   @default(0) @db.Decimal(18, 2)
  rate               Decimal?                  @db.Decimal(6, 4) // 百分比或時薪率
  isTaxable          Boolean                   @default(true) // 是否計入所得稅
  isInsuranceBase    Boolean                   @default(true) // 是否計入勞健保投保薪資
  isPensionBase      Boolean                   @default(true) // 是否計入勞退投保薪資
  description        String?
  isActive           Boolean                   @default(true)
  updatedBy          String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  employeeStructures EmployeeSalaryStructure[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
  @@index([isActive])
}

/// 員工薪資結構關聯
model EmployeeSalaryStructure {
  id            String          @id @default(cuid())
  employeeId    String
  structureId   String
  effectiveDate DateTime // 生效日期
  amount        Decimal         @default(0) @db.Decimal(18, 2) // 個別化金額
  rate          Decimal?        @db.Decimal(6, 4) // 個別化比率
  isActive      Boolean         @default(true)
  expiredAt     DateTime?
  createdAt     DateTime        @default(now())
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  structure     SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  @@unique([employeeId, structureId, effectiveDate])
  @@index([employeeId])
  @@index([structureId])
  @@index([effectiveDate])
  @@index([isActive])
}

// ─────────────────────────── 薪資異動管理 ───────────────────────────
enum SalaryChangeType {
  HIRED // 入職
  PROMOTION // 升職
  DEMOTION // 降職
  RAISE // 調薪
  TRANSFER // 調動
  RESIGNATION // 離職
  RETIREMENT // 退休
  OTHER // 其他
}

enum SalaryChangeStatus {
  DRAFT // 草稿
  SUBMITTED // 已提交
  APPROVED // 已核准
  REJECTED // 已駁回
  EFFECTIVE // 已生效
}

/// 薪資異動記錄
model SalaryChange {
  id              String             @id @default(cuid())
  tenantId        String
  number          String // 異動單號 e.g. SC-202601-0001
  employeeId      String
  type            SalaryChangeType
  status          SalaryChangeStatus @default(DRAFT)
  effectiveDate   DateTime // 生效日期
  // 異動前資訊
  oldDepartmentId String?
  oldPosition     String?
  oldBaseSalary   Decimal?           @db.Decimal(18, 2)
  oldTotalSalary  Decimal?           @db.Decimal(18, 2)
  // 異動後資訊
  newDepartmentId String?
  newPosition     String?
  newBaseSalary   Decimal?           @db.Decimal(18, 2)
  newTotalSalary  Decimal?           @db.Decimal(18, 2)
  // 異動原因
  reason          String?
  approvedBy      String? // 核准人
  approvedAt      DateTime?
  remark          String?
  updatedBy       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  employee        Employee           @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([employeeId])
  @@index([effectiveDate])
  @@index([status])
  @@index([type])
}

// ─────────────────────────── 固定資產 ───────────────────────────
enum DepreciationMethod {
  STRAIGHT_LINE // 直線法
  DOUBLE_DECLINING // 倍數餘額遞減
  SUM_OF_YEARS // 年數合計
  NONE
}

enum FixedAssetStatus {
  IN_USE // 使用中
  IDLE // 閒置
  DISPOSED // 已處分
  IMPAIRED // 減損
}

enum FixedAssetDepreciationStatus {
  CONFIRMED // 已確認、尚未切製傳票
  POSTED // 已切製並過帳傳票
  REVERSED // 傳票已沖銷
}

/// 固定資產目錄
model FixedAsset {
  id                      String                   @id @default(cuid())
  tenantId                String
  code                    String // 資產編號
  name                    String // 資產名稱
  category                String? // 分類 (土地/建築/設備...)
  accountCode             String? // 對應會計科目代碼 (1401, 1421...)
  acquireDate             DateTime // 取得日
  acquireCost             Decimal                  @db.Decimal(18, 2)
  residualValue           Decimal                  @default(0) @db.Decimal(18, 2)
  usefulLifeMonths        Int                      @default(60) // 耐用年限(月)
  method                  DepreciationMethod       @default(STRAIGHT_LINE)
  accumulatedDepreciation Decimal                  @default(0) @db.Decimal(18, 2)
  bookValue               Decimal                  @db.Decimal(18, 2)
  location                String?
  serialNumber            String?
  supplierId              String?
  status                  FixedAssetStatus         @default(IN_USE)
  disposeDate             DateTime?
  disposeAmount           Decimal?                 @db.Decimal(18, 2)
  remark                  String?
  sourceJournalId         String? // 來源傳票 (若由傳票自動建立)
  updatedBy               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  depreciations           FixedAssetDepreciation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([status])
}

/// 固定資產折舊子帳；先確認折舊明細，再由使用者決定是否切製傳票。
model FixedAssetDepreciation {
  id                     String                       @id @default(cuid())
  tenantId               String
  fixedAssetId           String
  period                 String // YYYY-MM
  depreciationDate       DateTime
  amount                 Decimal                      @db.Decimal(18, 2)
  openingBookValue       Decimal                      @db.Decimal(18, 2)
  closingBookValue       Decimal                      @db.Decimal(18, 2)
  method                 DepreciationMethod
  expenseAccountCode     String
  accumulatedAccountCode String
  status                 FixedAssetDepreciationStatus @default(CONFIRMED)
  journalEntryId         String?                      @unique
  note                   String?
  createdById            String?
  postedById             String?
  postedAt               DateTime?
  reversedAt             DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  tenant                 Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fixedAsset             FixedAsset                   @relation(fields: [fixedAssetId], references: [id], onDelete: Restrict)
  journalEntry           JournalEntry?                @relation("FixedAssetDepreciationJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)

  @@unique([tenantId, fixedAssetId, period])
  @@index([tenantId, depreciationDate])
  @@index([tenantId, status])
  @@index([fixedAssetId])
}

// ─────────────────────────── 醫美診所營運管理 POS ───────────────────────────
model MedicalService {
  id                String                     @id @default(cuid())
  tenantId          String
  productId         String                     @unique
  code              String
  category          String
  durationMinutes   Int                        @default(60)
  bodyArea          String?
  equipmentName     String?
  consentRequired   Boolean                    @default(true)
  imageUrl          String?
  isActive          Boolean                    @default(true)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  consumables       MedicalServiceConsumable[]
  appointments      MedicalAppointment[]
  treatmentPackages MedicalTreatmentPackage[]
  consents          MedicalConsent[]
  treatmentRecords  MedicalTreatmentRecord[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive, category])
}

model MedicalServiceConsumable {
  id        String         @id @default(cuid())
  serviceId String
  productId String
  quantity  Decimal        @db.Decimal(18, 4)
  unit      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  service   MedicalService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([serviceId, productId])
  @@index([productId])
}

model MedicalAppointment {
  id               String                  @id @default(cuid())
  tenantId         String
  customerId       String
  serviceId        String
  posSaleId        String?                 @unique
  number           String
  startAt          DateTime
  endAt            DateTime
  status           String                  @default("BOOKED")
  practitionerName String
  room             String?
  notes            String?
  consentStatus    String                  @default("PENDING")
  createdById      String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service          MedicalService          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  posSale          PosSale?                @relation(fields: [posSaleId], references: [id], onDelete: SetNull)
  consents         MedicalConsent[]
  treatmentRecord  MedicalTreatmentRecord?
  receipts         MedicalReceipt[]

  @@unique([tenantId, number])
  @@index([tenantId, startAt, status])
  @@index([customerId, startAt])
  @@index([serviceId, startAt])
}

model MedicalTreatmentPackage {
  id        String                   @id @default(cuid())
  tenantId  String
  productId String                   @unique
  serviceId String
  code      String
  name      String
  sessions  Int
  validDays Int                      @default(365)
  imageUrl  String?
  isActive  Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product                  @relation(fields: [productId], references: [id], onDelete: Restrict)
  service   MedicalService           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  purchases MedicalPackagePurchase[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([serviceId])
}

model MedicalPackagePurchase {
  id                String                   @id @default(cuid())
  tenantId          String
  customerId        String
  packageId         String
  posSaleId         String?                  @unique
  number            String
  totalSessions     Int
  remainingSessions Int
  paidAmount        Decimal                  @db.Decimal(18, 2)
  validUntil        DateTime
  status            String                   @default("ACTIVE")
  purchasedAt       DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer          Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  package           MedicalTreatmentPackage  @relation(fields: [packageId], references: [id], onDelete: Restrict)
  posSale           PosSale?                 @relation(fields: [posSaleId], references: [id], onDelete: SetNull)
  treatmentRecords  MedicalTreatmentRecord[]

  @@unique([tenantId, number])
  @@index([tenantId, status, validUntil])
  @@index([customerId, status])
}

model MedicalWallet {
  id           String                     @id @default(cuid())
  tenantId     String
  customerId   String                     @unique
  balance      Decimal                    @default(0) @db.Decimal(18, 2)
  updatedAt    DateTime                   @updatedAt
  createdAt    DateTime                   @default(now())
  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  transactions MedicalWalletTransaction[]

  @@index([tenantId, updatedAt])
}

model MedicalWalletTransaction {
  id            String          @id @default(cuid())
  tenantId      String
  walletId      String
  number        String
  type          String
  amount        Decimal         @db.Decimal(18, 2)
  balanceAfter  Decimal         @db.Decimal(18, 2)
  paymentMethod String?
  reference     String?
  note          String?
  createdById   String
  createdAt     DateTime        @default(now())
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wallet        MedicalWallet   @relation(fields: [walletId], references: [id], onDelete: Restrict)
  receipt       MedicalReceipt?

  @@unique([tenantId, number])
  @@index([walletId, createdAt])
  @@index([tenantId, type, createdAt])
}

model MedicalConsent {
  id              String              @id @default(cuid())
  tenantId        String
  customerId      String
  serviceId       String
  appointmentId   String?
  title           String
  documentVersion String
  status          String              @default("PENDING")
  signedName      String?
  responses       Json?
  acceptedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service         MedicalService      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appointment     MedicalAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([appointmentId])
}

model MedicalTreatmentRecord {
  id                        String                  @id @default(cuid())
  tenantId                  String
  appointmentId             String                  @unique
  customerId                String
  serviceId                 String
  packagePurchaseId         String?
  practitionerName          String
  treatmentNotes            String?
  beforePhotoUrl            String?
  afterPhotoUrl             String?
  deferredRevenueRecognized Decimal                 @default(0) @db.Decimal(18, 2)
  completedAt               DateTime                @default(now())
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  tenant                    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment               MedicalAppointment      @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  customer                  Customer                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service                   MedicalService          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  packagePurchase           MedicalPackagePurchase? @relation(fields: [packagePurchaseId], references: [id], onDelete: Restrict)

  @@index([tenantId, completedAt])
  @@index([customerId, completedAt])
  @@index([serviceId, completedAt])
}

model MedicalReceipt {
  id                  String                    @id @default(cuid())
  tenantId            String
  posSaleId           String?                   @unique
  walletTransactionId String?                   @unique
  appointmentId       String?
  customerId          String
  number              String
  patientName         String
  patientIdentity     String?
  birthDate           DateTime?
  gender              String?
  medicalRecordNo     String?
  practitionerName    String?
  department          String                    @default("醫學美容")
  visitDate           DateTime                  @default(now())
  medicalItems        Json
  nonMedicalItems     Json?
  medicalAmount       Decimal                   @default(0) @db.Decimal(18, 2)
  nonMedicalAmount    Decimal                   @default(0) @db.Decimal(18, 2)
  total               Decimal                   @db.Decimal(18, 2)
  status              String                    @default("ISSUED")
  voidReason          String?
  issuedByName        String
  issuedAt            DateTime                  @default(now())
  voidedAt            DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  tenant              Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posSale             PosSale?                  @relation(fields: [posSaleId], references: [id], onDelete: SetNull)
  walletTransaction   MedicalWalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)
  appointment         MedicalAppointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customer            Customer                  @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@unique([tenantId, number])
  @@index([tenantId, issuedAt, status])
  @@index([customerId, issuedAt])
}
